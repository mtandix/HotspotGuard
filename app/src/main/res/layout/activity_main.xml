<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#0D1117"
    tools:context=".MainActivity">

    <!-- App Icon / Logo Area -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📡"
        android:textSize="64sp"
        android:layout_marginBottom="8dp" />

    <!-- App Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="HotspotGuard"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Auto Hotspot on 5G"
        android:textSize="14sp"
        android:textColor="#8B949E"
        android:layout_marginBottom="32dp" />

    <!-- Status Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#161B22"
        android:padding="20dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚫ INACTIVE - Not Monitoring"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#8B949E"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Press Start to begin automatic\nhotspot management based on 5G signal"
            android:textSize="13sp"
            android:textColor="#8B949E"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>

    <!-- Network Info Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#161B22"
        android:padding="20dp"
        android:layout_marginBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NETWORK STATUS"
            android:textSize="11sp"
            android:textColor="#8B949E"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvNetworkInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Checking..."
            android:textSize="14sp"
            android:textColor="#FFFFFF" />

    </LinearLayout>

    <!-- Main Toggle Button -->
    <Button
        android:id="@+id/btnToggle"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="▶️ Start Monitoring"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:backgroundTint="#238636"
        android:layout_marginBottom="16dp" />

    <!-- Info Text -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Requires Shizuku to be running"
        android:textSize="12sp"
        android:textColor="#8B949E"
        android:gravity="center" />

</LinearLayout>
